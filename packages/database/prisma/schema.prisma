generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── MULTI-TENANCY ────────────────────────────────────────────────────────────

model Tenant {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  plan      Plan     @default(FREE)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users        User[]
  invitations  Invitation[]
  stores       Store[]
  products     Product[]
  orders       Order[]
  warehouses   Warehouse[]
  nfeSettings  NfeSettings?
  returns      Return[]

  @@map("tenants")
}

model User {
  id           String   @id @default(cuid())
  tenantId     String
  email        String   @unique
  name         String
  passwordHash String?
  role         UserRole @default(OPERATOR)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("users")
}

model Invitation {
  id        String           @id @default(cuid())
  tenantId  String
  email     String
  role      UserRole         @default(OPERATOR)
  token     String           @unique @default(cuid())
  status    InvitationStatus @default(PENDING)
  invitedBy String
  expiresAt DateTime
  createdAt DateTime         @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, email])
  @@map("invitations")
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  EXPIRED
}

enum Plan {
  FREE
  STARTER
  GROWTH
  PRO
}

enum UserRole {
  OWNER
  ADMIN
  OPERATOR
}

// ─── INTEGRAÇÕES COM MARKETPLACES ────────────────────────────────────────────

model Store {
  id           String      @id @default(cuid())
  tenantId     String
  marketplace  Marketplace
  name         String
  externalId   String
  accessToken  String
  refreshToken String?
  tokenExpiry  DateTime?
  isActive     Boolean     @default(true)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  tenant       Tenant                 @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  listings     Listing[]
  orders       Order[]
  returns      Return[]               @relation("ReturnStore")
  financialTxs FinancialTransaction[] @relation("FinancialStore")

  @@unique([tenantId, marketplace, externalId])
  @@map("stores")
}

enum Marketplace {
  MERCADO_LIVRE
  SHOPEE
  AMAZON
  MAGALU
  AMERICANAS
  SHEIN
  TIKTOK_SHOP
  SHOPIFY
  NUVEMSHOP
}

// ─── CATÁLOGO DE PRODUTOS (PIM) ───────────────────────────────────────────────

model Product {
  id          String   @id @default(cuid())
  tenantId    String
  sku         String
  name        String
  description String?
  brand       String?
  ncm         String?
  gtin        String?
  weight      Float?
  height      Float?
  width       Float?
  length      Float?
  images      String[]
  attributes  Json     @default("{}")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant       Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  listings     Listing[]
  stockItems   StockItem[]
  kitItems     KitItem[]
  kitOf        KitItem[]     @relation("KitProduct")
  orderItems   OrderItem[]

  @@unique([tenantId, sku])
  @@map("products")
}

model Listing {
  id           String        @id @default(cuid())
  storeId      String
  productId    String
  externalId   String
  title        String
  price        Decimal       @db.Decimal(12, 2)
  status       ListingStatus @default(ACTIVE)
  url          String?
  categoryId   String?
  syncedAt     DateTime?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  store   Store   @relation(fields: [storeId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])

  @@unique([storeId, externalId])
  @@map("listings")
}

enum ListingStatus {
  ACTIVE
  PAUSED
  CLOSED
  UNDER_REVIEW
}

// ─── ESTOQUE (WMS) ────────────────────────────────────────────────────────────

model Warehouse {
  id        String   @id @default(cuid())
  tenantId  String
  name      String
  isDefault Boolean  @default(false)
  address   Json?
  createdAt DateTime @default(now())

  tenant     Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  stockItems StockItem[]

  @@map("warehouses")
}

model StockItem {
  id          String    @id @default(cuid())
  productId   String
  warehouseId String
  quantity    Int       @default(0)
  reserved    Int       @default(0)
  minAlert    Int       @default(5)
  updatedAt   DateTime  @updatedAt

  product   Product   @relation(fields: [productId], references: [id])
  warehouse Warehouse @relation(fields: [warehouseId], references: [id])

  @@unique([productId, warehouseId])
  @@map("stock_items")
}

model StockMovement {
  id          String        @id @default(cuid())
  productId   String
  warehouseId String
  type        MovementType
  quantity    Int
  reason      String?
  orderId     String?
  createdAt   DateTime      @default(now())

  @@map("stock_movements")
}

model KitItem {
  id        String @id @default(cuid())
  kitId     String
  productId String
  quantity  Int    @default(1)

  kit     Product @relation(fields: [kitId], references: [id])
  product Product @relation("KitProduct", fields: [productId], references: [id])

  @@unique([kitId, productId])
  @@map("kit_items")
}

enum MovementType {
  IN
  OUT
  RESERVED
  RELEASED
  ADJUSTED
}

// ─── PEDIDOS (OMS) ────────────────────────────────────────────────────────────

model Order {
  id             String      @id @default(cuid())
  tenantId       String
  storeId        String
  externalId     String
  marketplace    Marketplace
  status         OrderStatus
  buyerName      String?
  buyerDocument  String?
  buyerEmail     String?
  shippingAddr   Json?
  subtotal       Decimal     @db.Decimal(12, 2)
  shippingCost   Decimal     @db.Decimal(12, 2) @default(0)
  discount       Decimal     @db.Decimal(12, 2) @default(0)
  total          Decimal     @db.Decimal(12, 2)
  currency       String      @default("BRL")
  paidAt         DateTime?
  shippedAt      DateTime?
  deliveredAt    DateTime?
  cancelledAt    DateTime?
  trackingCode   String?
  nfeKey         String?
  nfeStatus      NfeStatus?
  externalData   Json        @default("{}")
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  tenant   Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  store    Store       @relation(fields: [storeId], references: [id])
  items    OrderItem[]
  returns  Return[]

  @@unique([storeId, externalId])
  @@index([tenantId, status])
  @@index([tenantId, createdAt])
  @@map("orders")
}

model OrderItem {
  id         String  @id @default(cuid())
  orderId    String
  productId  String?
  externalId String?
  sku        String
  name       String
  quantity   Int
  unitPrice  Decimal @db.Decimal(12, 2)
  total      Decimal @db.Decimal(12, 2)

  order   Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product? @relation(fields: [productId], references: [id])

  @@map("order_items")
}

enum OrderStatus {
  PENDING
  CONFIRMED
  INVOICED
  READY_TO_SHIP
  SHIPPED
  DELIVERED
  CANCELLED
  RETURNED
}

enum NfeStatus {
  PENDING
  AUTHORIZED
  CANCELLED
  REJECTED
}

// ─── CONFIGURAÇÃO FISCAL (NF-e) ───────────────────────────────────────────────

model NfeSettings {
  id         String @id @default(cuid())
  tenantId   String @unique
  cnpj       String
  ie         String?
  razaoSocial String
  uf         String
  crt        Int    @default(1)
  environment String @default("homologacao")
  certificate String?
  certPassword String?

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("nfe_settings")
}

// ─── PRECIFICAÇÃO ─────────────────────────────────────────────────────────────

model PricingRule {
  id          String      @id @default(cuid())
  tenantId    String
  name        String
  marketplace Marketplace?
  type        PricingType
  value       Decimal     @db.Decimal(10, 4)
  isActive    Boolean     @default(true)
  createdAt   DateTime    @default(now())

  @@map("pricing_rules")
}

enum PricingType {
  MARKUP_PERCENTAGE
  MARGIN_PERCENTAGE
  FIXED_ADDITION
  FIXED_PRICE
}

// ─── DEVOLUÇÕES (RMA) ─────────────────────────────────────────────────────────

model Return {
  id           String       @id @default(cuid())
  tenantId     String
  orderId      String
  storeId      String
  marketplace  Marketplace
  externalId   String?
  reason       ReturnReason
  status       ReturnStatus @default(REQUESTED)
  buyerNote    String?
  sellerNote   String?
  refundAmount Decimal?     @db.Decimal(12, 2)
  trackingCode String?
  images       String[]
  resolvedAt   DateTime?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  tenant Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  order  Order       @relation(fields: [orderId], references: [id])
  store  Store       @relation("ReturnStore", fields: [storeId], references: [id])
  items  ReturnItem[]

  @@index([tenantId, status])
  @@index([tenantId, createdAt])
  @@map("returns")
}

model ReturnItem {
  id        String  @id @default(cuid())
  returnId  String
  sku       String
  name      String
  quantity  Int
  unitPrice Decimal @db.Decimal(12, 2)

  return Return @relation(fields: [returnId], references: [id], onDelete: Cascade)

  @@map("return_items")
}

enum ReturnReason {
  DEFECTIVE
  WRONG_ITEM
  NOT_AS_DESCRIBED
  BUYER_REMORSE
  LATE_DELIVERY
  DAMAGED_PACKAGING
  OTHER
}

enum ReturnStatus {
  REQUESTED
  APPROVED
  IN_TRANSIT
  RECEIVED
  INSPECTING
  REFUNDED
  REJECTED
  CLOSED
}

// ─── FINANCEIRO ───────────────────────────────────────────────────────────────

model FinancialTransaction {
  id            String           @id @default(cuid())
  tenantId      String
  orderId       String?
  storeId       String?
  marketplace   Marketplace?
  type          FinancialTxType
  amount        Decimal          @db.Decimal(12, 4)
  currency      String           @default("BRL")
  description   String?
  externalId    String?
  referenceDate DateTime
  createdAt     DateTime         @default(now())

  order Store? @relation("FinancialStore", fields: [storeId], references: [id])

  @@index([tenantId, referenceDate])
  @@index([tenantId, type])
  @@map("financial_transactions")
}

enum FinancialTxType {
  SALE
  MARKETPLACE_FEE
  SHIPPING_COST
  SHIPPING_CREDIT
  COMMISSION
  REFUND
  CHARGEBACK
  ADVERTISEMENT
  OTHER
}

// ─── NOTIFICAÇÕES PUSH ────────────────────────────────────────────────────────

model PushToken {
  id        String   @id @default(cuid())
  tenantId  String
  userId    String
  token     String
  platform  String   @default("unknown")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([tenantId, token])
  @@map("push_tokens")
}
